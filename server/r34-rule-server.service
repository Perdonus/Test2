[Unit]
Description=R34 Rule backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/r34
Environment=RULE_SERVER_HOST=127.0.0.1
Environment=RULE_SERVER_PORT=5006
Environment=RULE_PUBLIC_BASE_URL=https://sosiskibot.ru/rule
Environment=RULE_SERVER_DATA_ROOT=/var/lib/r34-rule
Environment=RULE_AI_MODEL=sonar-pro
ExecStart=/usr/bin/python3 /root/r34/server/rule_server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
